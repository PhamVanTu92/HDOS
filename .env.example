# ─── HDOS ReportingPlatform — Environment Configuration ──────────────────────
# Copy file này thành .env rồi điền các giá trị phù hợp
# KHÔNG commit file .env vào git (đã có trong .gitignore)
#
#   cp .env.example .env

# ─── QUAN TRỌNG: IP / hostname của server ────────────────────────────────────
#
# Đặt thành IP hoặc hostname mà CẢ HAI bên có thể truy cập:
#   • Trình duyệt người dùng  (browser)
#   • Các Docker container bên trong
#
# Cách tìm IP trên Ubuntu:
#   ip route get 1 | awk '{print $7; exit}'
#
# Ví dụ:
#   HDOS_HOST=192.168.1.100       ← server trong mạng LAN
#   HDOS_HOST=10.0.0.5            ← server trong VPN / cloud
#   HDOS_HOST=myserver.company    ← nếu có domain trỏ về server
#
# ⚠ KHÔNG dùng "localhost" — Docker containers không thể reach localhost của host
HDOS_HOST=192.168.1.100

# ─── Auth (tự động tính từ HDOS_HOST) ───────────────────────────────────────
# Keycloak issuer URL — phải trùng với URL browsers dùng để login
# AUTH_AUTHORITY=http://${HDOS_HOST}:8180/realms/hdos   ← tự động set
AUTH_AUDIENCE=reporting-platform

# ─── CORS (frontend origins được phép gọi Gateway) ───────────────────────────
# !! KHÔNG dùng "*" — SignalR WebSocket cần AllowCredentials() !!
CORS_ORIGIN_0=http://${HDOS_HOST}:3000
CORS_ORIGIN_1=http://localhost:3000

# ─── Excel Provider ──────────────────────────────────────────────────────────
# Secret dùng để đăng ký Excel Provider với platform.
# KHÔNG đổi sau khi đã seed database lần đầu (hoặc phải xóa provider và re-seed).
EXCEL_PROVIDER_SECRET=excel-secret-dev-2024

# ─── Keycloak Admin credentials ──────────────────────────────────────────────
# Admin UI: http://<HDOS_HOST>:8180
# Login:    admin / Admin123!
#
# Test users (tạo sẵn qua realm-import.json):
#   admin     / Admin123!   (role: admin,  tenant_id: tenant-001)
#   testuser  / User123!    (role: user,   tenant_id: tenant-001)

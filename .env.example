# ─── HDOS ReportingPlatform — Environment Configuration ──────────────────────
# Copy file này thành .env rồi điền các giá trị phù hợp
# KHÔNG commit file .env vào git (đã có trong .gitignore)
#
#   cp .env.example .env

# ─── Domain / hostname của HDOS ───────────────────────────────────────────────
#
# Phải trùng với domain đã trỏ DNS về server.
# Dùng domain này ở CẢ HAI phía: browser + Docker container (qua BackchannelHttpHandler).
#
# Production:
HDOS_HOST=hdosfoxai.foxai.com.vn

# Khi chạy local (dev):
# HDOS_HOST=192.168.1.100

# ─── CORS (frontend origins được phép gọi Gateway) ───────────────────────────
# !! KHÔNG dùng "*" — SignalR WebSocket cần AllowCredentials() !!
CORS_ORIGIN_0=https://${HDOS_HOST}
CORS_ORIGIN_1=https://localhost

# ─── Audience ─────────────────────────────────────────────────────────────────
AUTH_AUDIENCE=reporting-platform

# ─── Excel Provider secret ────────────────────────────────────────────────────
# Phải khớp với giá trị seeded vào provider_registry.client_secret_hash
EXCEL_PROVIDER_SECRET=excel-secret-dev-2024

# ─── Keycloak Admin credentials ──────────────────────────────────────────────
# Admin UI (HTTPS): https://<HDOS_HOST>:8443
# Login:    admin / Admin123!
#
# Test users (tạo sẵn qua realm-import.json):
#   admin     / Admin123!   (role: admin,  tenant_id: tenant-001)
#   testuser  / User123!    (role: user,   tenant_id: tenant-001)

# ─── Truy cập sau khi deploy ──────────────────────────────────────────────────
# Frontend : https://hdosfoxai.foxai.com.vn        (cần host nginx + Let's Encrypt)
# Keycloak : https://hdosfoxai.foxai.com.vn:8443   (Keycloak Admin Console)
# RabbitMQ : http://<server-ip>:15672              (guest / guest — chỉ internal)
#
# Host ports HDOS chiếm (localhost only, không conflict với hệ thống khác):
#   127.0.0.1:17080  →  main app HTTP (nginx proxy vào)
#   127.0.0.1:17081  →  Keycloak Admin HTTP (nginx proxy vào)

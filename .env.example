# Copy file này thành .env và điền giá trị thực
# KHÔNG bao giờ commit file .env vào git
#
#   cp .env.example .env

# ─── Auth (OIDC) ─────────────────────────────────────────────────────────────
# AUTH_AUTHORITY để trống = tắt xác thực JWT (chỉ dùng khi dev/test local)
# Khi lên staging/production: điền URL OIDC provider thực
AUTH_AUTHORITY=
AUTH_AUDIENCE=reporting-platform

# ─── CORS ────────────────────────────────────────────────────────────────────
# !! KHÔNG dùng "*" !!
# Gateway dùng AllowCredentials() cho SignalR WebSocket auth.
# ASP.NET Core cấm kết hợp wildcard "*" + AllowCredentials() → crash khi start.
# Phải liệt kê origin cụ thể, ví dụ:
CORS_ORIGIN_0=http://localhost:3000
CORS_ORIGIN_1=http://localhost:5173
# Staging/production:
# CORS_ORIGIN_0=https://app.your-domain.com
# CORS_ORIGIN_1=https://staging.your-domain.com

# ─── Provider samples (docker-compose.providers.yml) ─────────────────────────
# Lấy giá trị sau khi đăng ký provider qua:
#   POST http://localhost:5500/api/v1/admin/providers
# Response trả về clientId và clientSecret (chỉ hiển thị 1 lần)

# DotnetProviderSample credentials
ML_FRAUD_CLIENT_ID=ml-team-fraud-REPLACE_ME
ML_FRAUD_CLIENT_SECRET=rp_sk_REPLACE_ME

# PythonProviderSample credentials
FORECAST_CLIENT_ID=forecast-python-REPLACE_ME
FORECAST_CLIENT_SECRET=rp_sk_REPLACE_ME

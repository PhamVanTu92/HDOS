{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "MassTransit": "Warning"
    }
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "RabbitMQ": {
    "Uri": "amqp://guest:guest@localhost/"
  },
  "Dispatcher": {
    "FallbackToUserGroup": true,
    "PrefetchCount": 8
  },
  "AllowedHosts": "*",
  "Urls": "http://+:5200"
}
